<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="top.javahai.chatroom.mapper.PrivateChatConversationMapper">

    <resultMap id="BaseResultMap" type="top.javahai.chatroom.entity.PrivateChatConversation">
        <id column="id" property="id" jdbcType="VARCHAR"/>
        <result column="user_id_1" property="userId1" jdbcType="INTEGER"/>
        <result column="user_id_2" property="userId2" jdbcType="INTEGER"/>
        <result column="create_time" property="createTime" jdbcType="TIMESTAMP"/>
        <result column="end_time" property="endTime" jdbcType="TIMESTAMP"/>
        <result column="is_active" property="isActive" jdbcType="BOOLEAN"/>
    </resultMap>

    <insert id="insert" parameterType="top.javahai.chatroom.entity.PrivateChatConversation">
        INSERT INTO private_chat_conversation
            (id, user_id_1, user_id_2, create_time, is_active)
        VALUES
            (#{id}, #{userId1}, #{userId2}, #{createTime}, #{isActive})
    </insert>

    <update id="update" parameterType="top.javahai.chatroom.entity.PrivateChatConversation">
        UPDATE private_chat_conversation
        SET
            end_time = #{endTime},
            is_active = #{isActive}
        WHERE id = #{id}
    </update>

    <select id="queryById" resultMap="BaseResultMap">
        SELECT * FROM private_chat_conversation WHERE id = #{id}
    </select>

    <select id="getActiveConversation" resultMap="BaseResultMap">
        SELECT * FROM private_chat_conversation
        WHERE
            ((user_id_1 = #{userId1} AND user_id_2 = #{userId2})
                OR
             (user_id_1 = #{userId2} AND user_id_2 = #{userId1}))
          AND is_active = 1
        LIMIT 1
    </select>

</mapper>
